<UserControl x:Class="ProfiSysTask.UI.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Background="#FFAFAFAF">
    <UserControl.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007CC3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="25" Padding="20,15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="6">
            <Run Text="pro" FontWeight="Bold" Foreground="White" FontFamily="Dubai" FontSize="84"
             /><Run Text="fi" FontWeight="Bold" Foreground="#007CC3" FontFamily="Dubai" FontSize="84"
             /><Run Text="sys" FontWeight="Bold" Foreground="Black" FontFamily="Dubai" FontSize="84"/>
        </TextBlock>

        <Grid Grid.Row="1" Margin="40,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top">
                <Button Content="Importuj z plików .csv" 
                        Command="{Binding NavigateToImportCommand}" 
                        Style="{StaticResource RoundedButtonStyle}" 
                        Width="300" Height="60"/>

                <Border Background="White" CornerRadius="40" Margin="0,30,0,0" Width="350" MinHeight="250">
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Margin="30" VerticalAlignment="Center">
                        Wczytaj i połącz dane z plików <Bold>Documents.csv</Bold> oraz <Bold>DocumentItems.csv</Bold>.<LineBreak/><LineBreak/>
                        Pobrane informacje zostaną zwalidowane, a następnie automatycznie zapisane w lokalnej relacyjnej bazie danych (<Bold>ProfiSysData.db</Bold>), przygotowując system do pracy.
                    </TextBlock>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Top">
                <Button Content="Pobierz z bazy danych" 
                        Command="{Binding NavigateToDatabaseCommand}" 
                        Style="{StaticResource RoundedButtonStyle}" 
                        Width="300" Height="60"/>

                <Border Background="White" CornerRadius="40" Margin="0,30,0,0" Width="350" MinHeight="250">
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Margin="30" VerticalAlignment="Center">
                        Załaduj wcześniej zapisane dokumenty z domyślnej bazy <Bold>ProfiSysData.db</Bold> lub wskaż inny, istniejący plik bazy SQLite na dysku.<LineBreak/><LineBreak/>
                        W przypadku braku pliku, aplikacja automatycznie utworzy nową, pustą strukturę bazy gotową na dane.
                    </TextBlock>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>