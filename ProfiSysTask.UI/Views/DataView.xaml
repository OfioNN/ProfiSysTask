<UserControl x:Class="ProfiSysTask.UI.Views.DataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:vm="clr-namespace:ProfiSysTask.UI.ViewModels"
             xmlns:System="clr-namespace:System;assembly=mscorlib" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Background="#E6E6E6">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ModernSidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="4,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#005A9E"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#004A80"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernSidebarRedHoverButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernSidebarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#b81414"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#990000"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="6"/>
                            <Border x:Name="Overlay" Background="Black" CornerRadius="6" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.15"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="RoundActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="20"/>
                            <Border x:Name="Overlay" Background="Black" CornerRadius="20" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.15"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.3"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007CC3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="15"/>
                            <Border x:Name="Overlay" Background="Black" CornerRadius="15" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.15"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,10,10,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#007CC3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                                <Path x:Name="SortArrow" 
                                      Grid.Column="1" 
                                      Margin="8,0,0,0" 
                                      VerticalAlignment="Center" 
                                      Fill="#007CC3" 
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="Data" Value="M 0,5 L 5,0 L 10,5 Z"/>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="Data" Value="M 0,0 L 5,5 L 10,0 Z"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EEEEEE"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F8FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#007CC3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="HorizontalGridLinesBrush" Value="Transparent"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PillComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#007CC3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border CornerRadius="16" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 5 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter IsHitTestVisible="False" Margin="10,0,20,0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="White" BorderThickness="1" BorderBrush="#DDDDDD" MinWidth="{Binding ActualWidth, ElementName=ToggleButton}" CornerRadius="8" Margin="0,5,0,0">
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#006BB3"/>
                </Trigger>
                <Trigger Property="IsDropDownOpen" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PillTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#007CC3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#005A9E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <Grid>
                                <TextBlock x:Name="PlaceholderText"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#A0FFFFFF" 
                                           Margin="{TemplateBinding Padding}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>

                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#006BB3"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#007CC3">
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="1" Command="{Binding ImportDataCommand}" Style="{StaticResource ModernSidebarButtonStyle}">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                    <iconPacks:PackIconMaterial Kind="FileImport" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="Importuj pliki CSV" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="2" Command="{Binding LoadDataCommand}" Style="{StaticResource ModernSidebarButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="DatabaseRefresh" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="Pobierz bazę" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="3" Command="{Binding ExportDataCommand}" Style="{StaticResource ModernSidebarButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="FileExport" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="Eksportuj do CSV" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="4" Command="{Binding GenerateReportCommand}" Style="{StaticResource ModernSidebarButtonStyle}" ToolTip="Generuj raport dla dokumentu">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="FileChart" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="Generuj raport" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <Border Grid.Row="5" Height="1" Background="White" Opacity="0.3" Margin="15,0,15,10" VerticalAlignment="Bottom"/>

            <Button Grid.Row="6" Command="{Binding ClearDatabaseCommand}" Style="{StaticResource ModernSidebarRedHoverButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="DatabaseMinus" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="Wyczyść bazę" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="7" Command="{Binding GoBackCommand}" Style="{StaticResource ModernSidebarButtonStyle}" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="Wróć" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Column="1" Margin="15,10,15,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1.8*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Dokumenty" FontSize="18" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding AddDocumentCommand}" Style="{StaticResource PillButtonStyle}" Background="#008A00" Width="150" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Plus" Width="12" Height="12" Margin="0,1,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dodaj dokument" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <ComboBox Width="130" Margin="0,0,10,0" 
              Style="{StaticResource PillComboBoxStyle}"
              ItemsSource="{Binding FilterColumns}"
              SelectedItem="{Binding SelectedFilterColumn, UpdateSourceTrigger=PropertyChanged}"/>

                    <ComboBox Width="110" Margin="0,0,10,0" 
              ItemsSource="{Binding DateOperators}"
              SelectedItem="{Binding SelectedDateOperator}">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource PillComboBoxStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilterColumn}" Value="Data">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>

                    <Grid Width="180" Margin="0,0,0,0">

                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Tag="Szukaj dokumentu...">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource PillTextBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFilterColumn}" Value="Typ">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedFilterColumn}" Value="Data">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <ComboBox ItemsSource="{Binding DocumentTypes}" SelectedItem="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox" BasedOn="{StaticResource PillComboBoxStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFilterColumn}" Value="Typ">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>

                        <DatePicker SelectedDate="{Binding SearchDate, UpdateSourceTrigger=PropertyChanged}" 
                    Width="180" Height="32" HorizontalAlignment="Right"
                    VerticalContentAlignment="Center" BorderBrush="#CCCCCC" BorderThickness="1" 
                    Background="White" Cursor="Hand">

                            <DatePicker.Resources>
                                <Style TargetType="DatePickerTextBox">
                                    <Setter Property="IsReadOnly" Value="True"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Foreground" Value="#007CC3"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="5,0,0,0"/>
                                </Style>
                            </DatePicker.Resources>

                            <DatePicker.Style>
                                <Style TargetType="DatePicker">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFilterColumn}" Value="Data">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DatePicker.Style>
                        </DatePicker>

                    </Grid>
                </StackPanel>
            </Grid>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Documents}" SelectedItem="{Binding SelectedDocument}" 
                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                      Style="{StaticResource ModernDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" MinWidth="40"/>
                    <DataGridTextColumn Header="Typ" Binding="{Binding Type}" Width="*"/>
                    <DataGridTextColumn Header="Data" Binding="{Binding Date, StringFormat=\{0:yyyy-MM-dd\}}" Width="*"/>

                    <DataGridTextColumn Header="Imię" Binding="{Binding FirstName}" Width="*"/>
                    <DataGridTextColumn Header="Nazwisko" Binding="{Binding LastName}" Width="*"/>

                    <DataGridTextColumn Header="Miasto" Binding="{Binding City}" Width="*"/>

                    <DataGridTemplateColumn Header="Akcje" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Background="#5C42D0 " Style="{StaticResource GridActionButtonStyle}" 
                                            Command="{Binding DataContext.EditDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" ToolTip="Edytuj">
                                        <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                                    </Button>

                                    <Button Background="#D14545" Style="{StaticResource GridActionButtonStyle}" 
                                            Command="{Binding DataContext.DeleteDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" ToolTip="Usuń">
                                        <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button Background="#007CC3" Style="{StaticResource RoundActionButtonStyle}" Command="{Binding PreviousPageCommand}" Width="28" Height="28" Margin="0,0,10,0">
                    <iconPacks:PackIconMaterial Kind="ChevronLeft" Width="14" Height="14"/>
                </Button>
                <TextBlock Text="Strona " VerticalAlignment="Center" Foreground="#333333" FontSize="12"/>
                <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#007CC3" FontSize="12"/>
                <TextBlock Text=" z " VerticalAlignment="Center" Foreground="#333333" FontSize="12"/>
                <TextBlock Text="{Binding TotalPages}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333333" FontSize="12" Margin="0,0,10,0"/>
                <Button Background="#007CC3" Style="{StaticResource RoundActionButtonStyle}" Command="{Binding NextPageCommand}" Width="28" Height="28">
                    <iconPacks:PackIconMaterial Kind="ChevronRight" Width="14" Height="14"/>
                </Button>
            </StackPanel>

            <Grid Grid.Row="4" Margin="0,0,0,10">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedDocument}" Value="{x:Null}">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Elementy dokumentu" FontSize="18" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding AddItemCommand}" Style="{StaticResource PillButtonStyle}" Background="#008A00" Width="140" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Plus" Width="12" Height="12" Margin="0,1,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dodaj pozycję" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <ComboBox Width="130" Margin="0,0,10,0" 
                              Style="{StaticResource PillComboBoxStyle}"
                              ItemsSource="{Binding ItemFilterColumns}"
                              SelectedItem="{Binding SelectedItemFilterColumn, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <ComboBox Width="100" Margin="0,0,10,0"
                              ItemsSource="{Binding PriceOperators}"
                              SelectedItem="{Binding SelectedPriceOperator, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource PillComboBoxStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItemFilterColumn}" Value="Cena">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                    
                    <Grid Width="180" Margin="0,0,0,0">

                        <TextBox Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}" Tag="Szukaj elementu...">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource PillTextBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedItemFilterColumn}" Value="Produkt">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedItemFilterColumn}" Value="VAT">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <ComboBox ItemsSource="{Binding ProductsList}" SelectedItem="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox" BasedOn="{StaticResource PillComboBoxStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedItemFilterColumn}" Value="Produkt">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>

                        <ComboBox ItemsSource="{Binding VatRatesStringList}" SelectedItem="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox" BasedOn="{StaticResource PillComboBoxStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedItemFilterColumn}" Value="VAT">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Grid>

            <DataGrid Grid.Row="5" ItemsSource="{Binding ItemsView}" SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Style>
                    <Style TargetType="DataGrid" BasedOn="{StaticResource ModernDataGridStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedDocument}" Value="{x:Null}">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Style>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Lp." Binding="{Binding Ordinal}" Width="Auto" MinWidth="40"/>
                    <DataGridTextColumn Header="Produkt" Binding="{Binding Product}" Width="2*"/>
                    <DataGridTextColumn Header="Ilość" Binding="{Binding Quantity}" Width="*"/>
                    <DataGridTextColumn Header="Cena" Binding="{Binding Price, StringFormat=\{0:C\}}" Width="*"/>
                    <DataGridTextColumn Header="VAT" Binding="{Binding TaxRate, StringFormat=\{0:0\}%}" Width="*"/>

                    <DataGridTemplateColumn Header="Akcje" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Background="#5C42D0" Style="{StaticResource GridActionButtonStyle}" 
                                            Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" ToolTip="Edytuj">
                                        <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                                    </Button>
                                    <Button Background="#D14545" Style="{StaticResource GridActionButtonStyle}" 
                                            Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" ToolTip="Usuń">
                                        <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Grid Grid.ColumnSpan="2" 
              Background="#B2000000" 
              Visibility="{Binding IsDocumentFormOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" 
              Panel.ZIndex="998">
            <Border Background="White" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Padding="25">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <iconPacks:PackIconMaterial Kind="FileDocumentEdit" Foreground="#007CC3" Width="24" Height="24" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DocumentFormTitle}" FontSize="18" FontWeight="Bold" Foreground="#333333" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Typ dokumentu *" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding DocumentTypes}" SelectedItem="{Binding EditingDocument.Type}" Height="35" Padding="10,0" Margin="0,0,0,15" Cursor="Hand" VerticalContentAlignment="Center" BorderBrush="#CCCCCC"/>

                    <TextBlock Text="Data *" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding EditingDocument.Date}" Height="35" Margin="0,0,0,15" Cursor="Hand" VerticalContentAlignment="Center" BorderBrush="#CCCCCC">
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="IsReadOnly" Value="True"/>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Imię *" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding EditingDocument.FirstName}" Height="35" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#CCCCCC"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Nazwisko *" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding EditingDocument.LastName}" Height="35" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#CCCCCC"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Miasto *" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding EditingDocument.City}" Height="35" Padding="10,0" Margin="0,0,0,25" VerticalContentAlignment="Center" BorderBrush="#CCCCCC"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Anuluj" Command="{Binding CancelDocumentFormCommand}" Style="{StaticResource PillButtonStyle}" Background="#666666" Width="100"/>
                        <Button Content="Zapisz" Command="{Binding SaveDocumentCommand}" Style="{StaticResource PillButtonStyle}" Background="#008A00" Width="120" Margin="15,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Border Background="{TemplateBinding Background}" CornerRadius="15"/>
                                        <Border x:Name="Overlay" Background="Black" CornerRadius="15" Opacity="0"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Overlay" Property="Opacity" Value="0.15"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Overlay" Property="Opacity" Value="0.3"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.ColumnSpan="2" 
              Background="#B2000000" 
              Visibility="{Binding IsItemFormOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" 
              Panel.ZIndex="998">

            <Border Background="White" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Width="380" Padding="25">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <iconPacks:PackIconMaterial Kind="PackageVariant" Foreground="#007CC3" Width="24" Height="24" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ItemFormTitle}" FontSize="18" FontWeight="Bold" Foreground="#333333" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Nazwa produktu *" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding ProductsList}" SelectedItem="{Binding EditingItem.Product}" Height="35" Padding="10,0" Margin="0,0,0,15" Cursor="Hand" VerticalContentAlignment="Center" BorderBrush="#CCCCCC"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ilość *" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,5"/>
                            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Height="35">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="35"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Command="{Binding DecreaseQuantityCommand}" Content="-" Background="#F0F0F0" Foreground="#333333" BorderThickness="0" FontSize="18" FontWeight="Bold" Cursor="Hand"/>

                                    <TextBox Grid.Column="1" Text="{Binding EditingItem.Quantity, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent"/>

                                    <Button Grid.Column="2" Command="{Binding IncreaseQuantityCommand}" Content="+" Background="#F0F0F0" Foreground="#333333" BorderThickness="0" FontSize="16" FontWeight="Bold" Cursor="Hand"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Cena jedn. (Netto) *" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding EditingItemPriceText, UpdateSourceTrigger=PropertyChanged}" 
                                     InputScope="Number" Tag="0.00"
                                     TextAlignment="Right" Height="35" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#CCCCCC"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,25">
                        <TextBlock Text="Stawka VAT (%) *" FontWeight="SemiBold" Foreground="#555555" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" Height="35" Padding="20,0" Background="#F9F9F9">

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton Content="8%" FontSize="14" FontWeight="SemiBold" Foreground="#333333" 
                                             Margin="0,0,30,0" VerticalContentAlignment="Center" Cursor="Hand"
                                             IsChecked="{Binding IsVat8}"/>

                                <RadioButton Content="23%" FontSize="14" FontWeight="SemiBold" Foreground="#333333" 
                                             VerticalContentAlignment="Center" Cursor="Hand"
                                             IsChecked="{Binding IsVat23}"/>
                            </StackPanel>

                        </Border>
                    </StackPanel>


                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Anuluj" Command="{Binding CancelItemFormCommand}" Style="{StaticResource PillButtonStyle}" Background="#666666" Width="90"/>
                        <Button Content="Zapisz pozycję" Command="{Binding SaveItemCommand}" Style="{StaticResource PillButtonStyle}" Background="#008A00" Width="130" Margin="15,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.ColumnSpan="2" 
              Background="#B2000000" 
              Visibility="{Binding IsConfirmDialogOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" 
              Panel.ZIndex="999">

            <Border Background="White" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Width="450" Padding="25">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <iconPacks:PackIconMaterial Width="24" Height="24" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial.Style>
                                <Style TargetType="iconPacks:PackIconMaterial">
                                    <Setter Property="Kind" Value="AlertCircleOutline"/>
                                    <Setter Property="Foreground" Value="#990000"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInfoOnlyMode}" Value="True">
                                            <Setter Property="Kind" Value="InformationOutline"/>
                                            <Setter Property="Foreground" Value="#007CC3"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsErrorMode}" Value="True">
                                            <Setter Property="Kind" Value="AlertOctagonOutline"/>
                                            <Setter Property="Foreground" Value="#E67E22"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </iconPacks:PackIconMaterial.Style>
                        </iconPacks:PackIconMaterial>

                        <TextBlock Text="{Binding ConfirmDialogTitle}" FontSize="18" FontWeight="Bold" Foreground="#333333" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ConfirmDialogMessage}" TextWrapping="Wrap" FontSize="14" Foreground="#555555" Margin="0,0,0,25" LineHeight="20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                        <Button Command="{Binding ConfirmDialogNoCommand}" Width="100">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
                                    <Setter Property="Content" Value="Anuluj"/>
                                    <Setter Property="Background" Value="#666666"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInfoOnlyMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsErrorMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Command="{Binding ConfirmDialogYesCommand}" Width="120" Margin="15,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
                                    <Setter Property="Content" Value="Tak, usuń"/>
                                    <Setter Property="Background" Value="#990000"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInfoOnlyMode}" Value="True">
                                            <Setter Property="Content" Value="Rozumiem"/>
                                            <Setter Property="Background" Value="#007CC3"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsErrorMode}" Value="True">
                                            <Setter Property="Content" Value="Ok"/>
                                            <Setter Property="Background" Value="#E67E22"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Border Background="{TemplateBinding Background}" CornerRadius="15"/>
                                        <Border x:Name="Overlay" Background="Black" CornerRadius="15" Opacity="0"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Overlay" Property="Opacity" Value="0.15"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Overlay" Property="Opacity" Value="0.3"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>